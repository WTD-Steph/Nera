# Supabase — dapatkan dari https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — dapatkan dari https://console.anthropic.com/settings/keys
# Server-only. JANGAN expose ke client.
ANTHROPIC_API_KEY=sk-ant-...

# AI model — default claude-opus-4-7. Override ke claude-sonnet-4-6 kalau
# perlu downgrade biaya/latency.
AI_MODEL=claude-opus-4-7
